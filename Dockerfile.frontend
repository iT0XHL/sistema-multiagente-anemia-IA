# ============================================================
#  AnemIA · Dockerfile.frontend (React + Webpack 5, build + Nginx)
#  El CSS se compila con la CLI de Tailwind (script "css", vía prebuild)
#  y el bundle con Webpack. En la ruta /app (sin "!") todo compila normal.
# ============================================================

# ── Etapa 1: build con Webpack + Tailwind CLI ────────────
FROM node:20-alpine AS build
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install
COPY frontend/ ./
ARG REACT_APP_API_URL=http://localhost:8000
ENV REACT_APP_API_URL=$REACT_APP_API_URL
RUN npm run build          # prebuild -> tailwind css; webpack -> dist/bundle.js

# ── Etapa 2: servir estáticos con Nginx ──────────────────
FROM nginx:1.27-alpine
# index.html + styles.css (public) y bundle.js (dist) al mismo directorio raíz.
COPY --from=build /app/public/ /usr/share/nginx/html/
COPY --from=build /app/dist/ /usr/share/nginx/html/
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
