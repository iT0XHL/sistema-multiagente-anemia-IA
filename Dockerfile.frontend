# ============================================================
#  AnemIA · Dockerfile.frontend (chatbot estático + Nginx)
#  El frontend es HTML + CSS + JS vanilla (Tailwind vía CDN); no requiere
#  build con Node. Se inyecta la URL real del backend en app.js.
# ============================================================
FROM nginx:1.27-alpine

ARG REACT_APP_API_URL=http://localhost:8000

# Estáticos del chatbot: index.html + /static/{styles.css, app.js}.
COPY frontend/public/ /usr/share/nginx/html/
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf

# Inyecta la URL del backend (reemplaza el marcador __API_BASE__ en app.js).
RUN sed -i "s|__API_BASE__|${REACT_APP_API_URL}|g" /usr/share/nginx/html/static/app.js

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
