{
  "name": "anemia-frontend",
  "private": true,
  "version": "2.0.0",
  "description": "Frontend React + TypeScript (Webpack 5) de AnemIA.",
  "scripts": {
    "css": "tailwindcss -i ./src/styles/index.css -o ./public/styles.css --minify",
    "prestart": "npm run css",
    "prebuild": "npm run css",
    "start": "webpack serve --mode development --host 0.0.0.0 --port 3000",
    "build": "webpack --mode production",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "framer-motion": "^11.15.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.0"
  }
}
