# ============================================================
#  AnemIA · Plantilla de variables de entorno
#  Copiar a .env antes de levantar el proyecto:  cp .env.example .env
#  (El .env real está en .gitignore; estos valores son dummy de prototipo.)
# ============================================================

# ── Base de datos PostgreSQL ─────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=anemia_db
POSTGRES_HOST=db
# Puerto del HOST para acceder a PostgreSQL desde fuera del contenedor.
# Cambiado a 5433 para no chocar con otro PostgreSQL en el 5432.
# (Dentro de Docker el contenedor sigue escuchando internamente en 5432.)
POSTGRES_PORT=5433

# URL usada por SQLAlchemy en el backend.
# En Docker el host es "db" y el puerto INTERNO 5432 (no el del host).
# En local sin Docker usar "localhost" y el puerto del host (5433).
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/anemia_db

# ── Backend (FastAPI) ────────────────────────────────────
BACKEND_PORT=8000
API_HOST=0.0.0.0
ENVIRONMENT=development
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:3000

# Modelo por defecto: random_forest | xgboost
DEFAULT_MODEL=random_forest

# ── pgAdmin (opcional) ───────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@anemia.local
PGADMIN_DEFAULT_PASSWORD=admin

# ── Frontend (React + Webpack) ───────────────────────────
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8000
