# ============================================================
#  AnemIA · Dockerfile.backend (FastAPI + ML + XAI)
# ============================================================
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

# Dependencias del sistema para numpy/scipy/xgboost/lime.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential libgomp1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Instala dependencias primero (mejor cacheo de capas).
COPY requirements.txt .
RUN pip install --upgrade pip && pip install -r requirements.txt

# Copia el código (backend + paquetes hermanos ml/agents/explainability).
COPY backend/ ./backend/
COPY ml/ ./ml/
COPY agents/ ./agents/
COPY explainability/ ./explainability/
COPY data/ ./data/

EXPOSE 8000

# Entrena los modelos si faltan y arranca la API.
CMD ["sh", "-c", "python ml/train_random_forest.py || true; uvicorn backend.app.main:app --host 0.0.0.0 --port 8000"]
